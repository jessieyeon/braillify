{
  "name": "braillify",
  "version": "2.0.1",
  "author": "devfive",
  "repository": "https://github.com/dev-five-git/braillify",
  "main": "./pkg/index.js",
  "module": "./pkg/index.js",
  "exports": {
    ".": {
      "import": "./pkg/index.js",
      "require": "./pkg/index.js",
      "types": "./pkg/index.d.ts"
    }
  },
  "bugs": {
    "url": "https://github.com/dev-five-git/braillify/issues",
    "email": "contact@devfive.kr"
  },
  "description": "Braillify is a library for converting text to braille.",
  "files": [
    "pkg/index.d.ts",
    "pkg/index.js",
    "pkg/index_bg.wasm",
    "pkg/index_bg.wasm.d.ts",
    "pkg/index_bg.js"
  ],
  "homepage": "https://braillify.com",
  "keywords": [
    "braillify",
    "braille",
    "braille-converter",
    "braille-to-text",
    "text-to-braille",
    "wasm"
  ],
  "license": "Apache-2.0",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "wasm-pack build --target bundler --out-dir ./pkg --out-name index --release && bun run optimize",
    "optimize": "wasm-opt -Oz --enable-bulk-memory --enable-nontrapping-float-to-int --enable-sign-ext -o pkg/index_bg_opt.wasm pkg/index_bg.wasm && mv pkg/index_bg_opt.wasm pkg/index_bg.wasm",
    "test": "wasm-pack test --node"
  },
  "sideEffects": false,
  "type": "module",
  "types": "./pkg/index.d.ts",
  "devDependencies": {
    "binaryen": "^130.0.0"
  }
}